# Copy to `.env` and fill in. NEVER commit the real `.env`.
# In production, inject these via docker secrets / systemd EnvironmentFile (chmod 600).

# ---- Telegram (roles) ----
BOT_TOKEN=
# The owner who USES the bot to calculate commission.
USER_TELEGRAM_ID=123456789
# The developer who RECEIVES alerts (and may also use the bot).
# May be the same as USER_TELEGRAM_ID. Only these two IDs are whitelisted.
DEVELOPER_TELEGRAM_ID=123456789

# ---- Demo ----
# When true, all exchanges return fake data so you can test the UX without keys.
# NEVER enable in production.
DEMO_MODE=false

# ---- Secret encryption ----
# Fernet master key used to decrypt the exchange secrets below.
# Generate once with: python -m bot.security.secrets keygen
# Supply only at runtime via env; never write it to disk inside the repo.
MASTER_KEY=

# ---- Exchange API credentials ----
# Values may be either plaintext (basic mode) or Fernet tokens (encrypted mode);
# encrypted mode is enabled automatically when MASTER_KEY is set.
# Prepare encrypted values with: python -m bot.security.secrets encrypt
#
# Leave an exchange blank to skip it — the adapter will not be registered.
#
# SECURITY: create every key with affiliate/read scope ONLY.
# NEVER grant trade or withdraw permissions. Bybit: "Affiliate" permission only.
# Bind keys to the VPS IP where the exchange supports IP whitelisting.

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

WEEX_API_KEY=
WEEX_API_SECRET=
WEEX_API_PASSPHRASE=

GATE_API_KEY=
GATE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

MEXC_API_KEY=
MEXC_API_SECRET=
